<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="26dp"
    app:cardElevation="10dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <FrameLayout
            android:id="@+id/layoutColorDestino"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:background="#26C6DA">

            <TextView
                android:id="@+id/txtIconoDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌴"
                android:textSize="64sp" />

        </FrameLayout>

        <!-- CONTENIDO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/txtNombreDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bali"
                android:textColor="#000000"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtUbicacionDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Indonesia"
                android:textColor="#757575"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtCategoriaDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#E0F7FA"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="Playa"
                android:textColor="#00838F"
                android:textStyle="bold" />

            <!-- RUTA -->

            <TextView
                android:id="@+id/txtRutaDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Guayaquil → Bali"
                android:textColor="#424242"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- TIPO -->

            <TextView
                android:id="@+id/txtTipoInfoDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Vacacional"
                android:textColor="#616161"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtRatingDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="⭐ 4.9"
                android:textColor="#616161"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtPrecioDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="$1200"
                android:textColor="#00838F"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- BOTONES -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCancelarDialog"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#E0E0E0"
                    android:text="Cancelar"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/btnCarritoDialog"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#F57C00"
                    android:text="Agregar"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>