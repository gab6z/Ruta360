<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acerca de"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="15dp"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="217dp"
        android:layout_marginBottom="15dp"
        android:scaleType="centerCrop"
        android:src="@drawable/foto_grupal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Proyecto Ruta 360"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#4B944E"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="337dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="Integrantes:\n\n• CHAVEZ MIRANDA EDUARDO EMMANUEL\n• GONZALEZ ROMAN GABRIELA SOLANGE \n•
         NOBOA CHIPRE EMERSON ARIEL \n• PALACIOS MORIEL LEANDRO RENE \n• TORRES BOHORQUEZ DOMINICA LILIBETH"
        android:textColor="#333333"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnCerrar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Regresar"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4B944E"/>

</LinearLayout>