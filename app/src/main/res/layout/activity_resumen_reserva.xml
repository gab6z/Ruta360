<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".resumen_reserva">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnVolver"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="10dp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#00695C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ruta"
            android:textColor="#00695C"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="360"
            android:textColor="#E65100"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen de tu Reserva"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginBottom="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvDestinoSeleccionado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Destino: Ruta del Spondylus"
                        android:textSize="18sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="#EEEEEE" />

                    <TextView
                        android:id="@+id/tvPrecioBase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total a Pagar: $150.00"
                        android:textSize="20sp"
                        android:textColor="#00838F"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <Button
                android:id="@+id/btnIrAConstructor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+ Añadir Paquetes Adicionales"
                android:backgroundTint="#005A8D"
                android:layout_marginBottom="10dp"
                app:cornerRadius="10dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardResumenPaquete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#F1F8E9">
                <LinearLayout
                    android:padding="15dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦 Paquete Personalizado"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"/>
                    <TextView
                        android:id="@+id/tvDetallePaqueteExtra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detalle..."
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/tvFechaElegida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗓️ Seleccione Fecha de Viaje:"
                android:textStyle="bold"
                android:textColor="#546E7A"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSeleccionarFecha"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Elegir Fecha de Salida"
                android:backgroundTint="#00838F"
                android:layout_marginBottom="20dp"
                app:cornerRadius="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Método de Pago:"
                android:textStyle="bold"
                android:textColor="#546E7A"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgMetodoPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="15dp">

                <RadioButton
                    android:id="@+id/rbTarjeta"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tarjeta"/>

                <RadioButton
                    android:id="@+id/rbTransferencia"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Transferencia"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moneda de pago:"
                android:textStyle="bold"
                android:textColor="#546E7A"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spMoneda"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:layout_marginBottom="15dp"/>

            <CheckBox
                android:id="@+id/cbTerminosReserva"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acepto las políticas de cancelación."
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardInfoEfectivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#E3F2FD">

                <LinearLayout
                    android:padding="15dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏦 Instrucciones de Depósito:"
                        android:textStyle="bold"
                        android:textColor="#1565C0"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Banco Internacional\nCuenta Corriente: 1020304050\nA nombre de: Ruta360 S.A."
                        android:textSize="13sp"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnConfirmarCheckout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Confirmar y Pagar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="25dp"
                android:backgroundTint="#F57C00"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnCerrar"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancelar Reserva"
                android:textColor="#757575"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>