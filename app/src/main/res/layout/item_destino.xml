<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <FrameLayout
            android:id="@+id/imgDestino"
            android:layout_width="match_parent"
            android:layout_height="210dp">

            <!-- ICONO CENTRAL -->

            <TextView
                android:id="@+id/txtIconoDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌴"
                android:textSize="68sp" />

            <!-- FAVORITO -->

            <ImageView
                android:id="@+id/btnFavorito"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|end"
                android:layout_margin="14dp"
                android:background="@drawable/fondo_circulo_blanco"
                android:padding="8dp"
                android:src="@android:drawable/btn_star_big_off" />

            <!-- BADGE -->

            <TextView
                android:id="@+id/txtTipoDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="14dp"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Internacional"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- CONTENIDO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- TITULO -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtNombreDestino"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bali"
                        android:textColor="#111111"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtPaisDestino"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Indonesia"
                        android:textColor="#757575"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtRatingDestino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.9"
                    android:textColor="#F57C00"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- CATEGORIA -->

            <TextView
                android:id="@+id/txtCategoriaDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#F3F3F3"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Playa"
                android:textColor="#555555"
                android:textSize="12sp" />

            <!-- PRECIO -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desde"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtPrecioDestino"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$1499"
                        android:textColor="#00838F"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnReservar"
                    android:layout_width="140dp"
                    android:layout_height="50dp"
                    android:backgroundTint="#F57C00"
                    android:text="Ver más"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>