<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER DESTINO -->

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <!-- FONDO COLOR -->

            <ImageView
                android:id="@+id/imgDestino"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#E0E0E0" />

            <!-- ICONO -->

            <TextView
                android:id="@+id/txtIconoDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌴"
                android:textSize="52sp" />

            <!-- FAVORITO -->

            <ImageView
                android:id="@+id/btnFavorito"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/fondo_circulo_blanco"
                android:padding="8dp"
                android:src="@android:drawable/btn_star_big_off" />

        </FrameLayout>

        <!-- CONTENIDO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NOMBRE -->

            <TextView
                android:id="@+id/txtNombreDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bali"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- PAIS -->

            <TextView
                android:id="@+id/txtPaisDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Indonesia"
                android:textColor="#757575"
                android:textSize="14sp" />

            <!-- RATING -->

            <TextView
                android:id="@+id/txtRatingDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="⭐ 4.9"
                android:textColor="#757575"
                android:textSize="14sp" />

            <!-- PRECIO -->

            <TextView
                android:id="@+id/txtPrecioDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="$1499"
                android:textColor="#00838F"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- BOTON -->

            <Button
                android:id="@+id/btnReservar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#F57C00"
                android:text="Reservar"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>